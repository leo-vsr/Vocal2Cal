# Runtime app traffic on Vercel/serverless: use the Supabase transaction pooler URL (:6543)
DATABASE_URL="postgresql://postgres:password@db.project-ref.supabase.co:6543/postgres?pgbouncer=true"
# Prisma CLI / migrations: use the direct database URL (:5432) or your provider's direct connection string
DIRECT_URL="postgresql://postgres:password@db.project-ref.supabase.co:5432/postgres"
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3001/api/auth/google/callback"
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL="gemini-3.1-flash-lite-preview"
GEMINI_PARSE_MODEL="gemini-3.1-flash-lite-preview"
GEMINI_TRANSCRIBE_MODEL="gemini-3.1-flash-lite-preview"
DAILY_AI_LIMIT="50"
SESSION_SECRET="your-session-secret-min-32-chars"
CLIENT_URL="http://localhost:5173"
NODE_ENV="development"
ENABLE_DEV_HISTORY_MOCKS="true"
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
ADMIN_EMAILS="your-email@gmail.com"
